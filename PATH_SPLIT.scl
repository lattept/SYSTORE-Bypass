FUNCTION_BLOCK "PATH_SPLIT"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      Init_Split : Bool;
   END_VAR

   VAR_OUTPUT 
      Busy : Bool;
      ActivePath : Int;   // -1=none / 0=path0 / 1=path1 / 2=path2
   END_VAR

   VAR 
      LastGranted : Int;
      ValidPaths : Int;
      i : Int;
      Candidate : Int;
      Found : Bool;
      ReqCount : Int;
      SingleIndex : Int;
      CFG : Struct
         NumberOfPaths : Int;   // 2 or 3
         Req : Array[0..2] of Bool;   // from PATH.Hsk.Req_SrcMov
         Done : Array[0..2] of Bool;   // from PATH.Hsk.Done_SrcMov
      END_STRUCT;
      Grant : Array[0..2] of Bool;
   END_VAR


BEGIN
	    // --------------------------------------------------
	    // INIT
	    // --------------------------------------------------
	    IF #Init_Split THEN
	        FOR #i := 0 TO 2 DO
	            #Grant[#i] := FALSE;
	        END_FOR;
	        
	        #Busy := FALSE;
	        #ActivePath := -1;
	        #LastGranted := -1;
	        RETURN;
	    END_IF;
	    
	    // --------------------------------------------------
	    // Clamp number of paths
	    // --------------------------------------------------
	    IF #CFG.NumberOfPaths < 2 THEN
	        #ValidPaths := 2;
	    ELSIF #CFG.NumberOfPaths > 3 THEN
	        #ValidPaths := 3;
	    ELSE
	        #ValidPaths := #CFG.NumberOfPaths;
	    END_IF;
	    
	    // --------------------------------------------------
	    // If one path is already selected, hold it until done
	    // --------------------------------------------------
	    IF #Busy THEN
	        FOR #i := 0 TO 2 DO
	            #Grant[#i] := FALSE;
	        END_FOR;
	        
	        IF (#ActivePath >= 0) AND (#ActivePath < #ValidPaths) THEN
	            #Grant[#ActivePath] := TRUE;
	            
	            IF #CFG.Done[#ActivePath] THEN
	                #Grant[#ActivePath] := FALSE;
	                #Busy := FALSE;
	                #LastGranted := #ActivePath;
	                #ActivePath := -1;
	            END_IF;
	        ELSE
	            // Safety fallback
	            #Busy := FALSE;
	            #ActivePath := -1;
	        END_IF;
	        
	        RETURN;
	    END_IF;
	    
	    // --------------------------------------------------
	    // No active path -> clear all grants
	    // --------------------------------------------------
	    FOR #i := 0 TO 2 DO
	        #Grant[#i] := FALSE;
	    END_FOR;
	    
	    // --------------------------------------------------
	    // Count requests
	    // --------------------------------------------------
	    #ReqCount := 0;
	    #SingleIndex := -1;
	    
	    FOR #i := 0 TO #ValidPaths - 1 DO
	        IF #CFG.Req[#i] THEN
	            #ReqCount := #ReqCount + 1;
	            #SingleIndex := #i;
	        END_IF;
	    END_FOR;
	    
	    // --------------------------------------------------
	    // No request
	    // --------------------------------------------------
	    IF #ReqCount = 0 THEN
	        RETURN;
	    END_IF;
	    
	    // --------------------------------------------------
	    // Only one request -> let it go directly
	    // --------------------------------------------------
	    IF #ReqCount = 1 THEN
	        #Grant[#SingleIndex] := TRUE;
	        #Busy := TRUE;
	        #ActivePath := #SingleIndex;
	        RETURN;
	    END_IF;
	    
	    // --------------------------------------------------
	    // Two or more requests -> round-robin arbitration
	    // --------------------------------------------------
	    #Found := FALSE;
	    #Candidate := -1;
	    
	    FOR #i := 1 TO #ValidPaths DO
	        #Candidate := (#LastGranted + #i) MOD #ValidPaths;
	        
	        IF #CFG.Req[#Candidate] THEN
	            #Found := TRUE;
	            EXIT;
	        END_IF;
	    END_FOR;
	    
	    IF #Found THEN
	        #Grant[#Candidate] := TRUE;
	        #Busy := TRUE;
	        #ActivePath := #Candidate;
	    END_IF;
END_FUNCTION_BLOCK

